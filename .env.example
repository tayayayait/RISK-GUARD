# Frontend runtime
VITE_SUPABASE_URL=https://dkslgsguxlznapiygier.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key
VITE_SUPABASE_USE_AUTH_HEADERS=true
VITE_USE_FORM_LAW_BACKEND=true

# Optional fallback for legacy proxy server
# VITE_API_BASE_URL=http://localhost:8787

# Gemini AI Models API 
VITE_GEMINI_API_KEY=your-gemini-text-api-key
VITE_GEMINI_IMAGE_API_KEY=your-gemini-image-api-key
VITE_GEMINI_TEXT_MODEL=gemini-3-flash-preview
# text model routing is handled in-app (cost-first):
# - simple prompts -> gemini-3-flash-preview
# - long/structured or multimodal prompts -> gemini-3.1-pro-preview
# non-standard custom model names are tried first, then flash/pro pair as fallback.
# image generation uses models/{model}:generateContent and falls back to gemini-2.5-flash-image, gemini-3-pro-image-preview
VITE_GEMINI_IMAGE_MODEL=gemini-3.1-flash-image-preview
